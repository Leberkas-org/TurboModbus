<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackageId>TurboModbus</PackageId>
    <Version>0.1.0</Version>
    <Authors>leberkas-org</Authors>
    <Description>High-performance Modbus TCP client built on Akka.Streams</Description>
    <PackageTags>modbus;tcp;akka;streams;iot;scada;plc</PackageTags>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/leberkas-org/TurboModbus</PackageProjectUrl>
    <RepositoryUrl>https://github.com/leberkas-org/TurboModbus</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Akka.Streams" Version="1.5.68" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
